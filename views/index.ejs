<script src="./js/bootstrap.bundle.min.js"></script>
<!-- custom responsive sidebar logic + tooltips init -->
<script>
    // Toggle sidebar function (mobile & optional desktop collapse)
    const sidebar = document.getElementById('sidebarId');
    const overlay = document.getElementById('sidebarOverlay');

    function toggleSidebar() {
        if (!sidebar) return;
        const isMobile = window.innerWidth <= 768;
        if (isMobile) {
            sidebar.classList.toggle('show');
            if (overlay) overlay.classList.toggle('show');
            // prevent body scroll when sidebar open
            if (sidebar.classList.contains('show')) {
                document.body.style.overflow = 'hidden';
            } else {
                document.body.style.overflow = '';
            }
        } else {
            // Desktop behavior: optional collapse/expand minimal width (optional)
            // we can just make it compact or keep full, but for UX: let sidebar toggle width? 
            // but per requirement we keep it as responsive; we add mini mode if needed
            // for desktop, just toggle a small class to reduce width? Not mandatory, but elegant.
            // However user expects responsiveness: on desktop sidebar is always visible but we can allow collapse to icon?
            // To align with modern dashboards, we'll add a desktop minimal mode: 
            // toggle class "collapsed" on sidebar to shrink to 70px (icons only)
            sidebar.classList.toggle('desktop-collapsed');
            if (sidebar.classList.contains('desktop-collapsed')) {
                sidebar.style.width = '72px';
                document.querySelectorAll('.sidebar-text').forEach(el => el.style.display = 'none');
                document.querySelector('.sidebar hr')?.setAttribute('style', 'margin: 0.5rem 0');
            } else {
                sidebar.style.width = '280px';
                document.querySelectorAll('.sidebar-text').forEach(el => el.style.display = '');
            }
        }
    }

    // close sidebar when window resizes from mobile to desktop
    window.addEventListener('resize', function() {
        if (window.innerWidth > 768) {
            if (sidebar && sidebar.classList.contains('show')) {
                sidebar.classList.remove('show');
                if (overlay) overlay.classList.remove('show');
                document.body.style.overflow = '';
            }
            // ensure desktop width is consistent (remove inline width if needed)
            if (sidebar && !sidebar.classList.contains('desktop-collapsed')) {
                sidebar.style.width = '';
            }
        } else {
            // on mobile, if desktop-collapsed class exists, remove it and reset text
            if (sidebar && sidebar.classList.contains('desktop-collapsed')) {
                sidebar.classList.remove('desktop-collapsed');
                sidebar.style.width = '';
                document.querySelectorAll('.sidebar-text').forEach(el => el.style.display = '');
            }
        }
    });

    // initial tooltips activation
    var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    tooltipTriggerList.forEach(function (tooltipTriggerEl) {
        new bootstrap.Tooltip(tooltipTriggerEl);
    });

    // close sidebar on escape key
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && window.innerWidth <= 768 && sidebar && sidebar.classList.contains('show')) {
            toggleSidebar();
        }
    });

    // optional: smooth close when clicking on nav links (mobile)
    if (sidebar) {
        const navLinks = sidebar.querySelectorAll('.nav-link');
        navLinks.forEach(link => {
            link.addEventListener('click', () => {
                if (window.innerWidth <= 768) {
                    toggleSidebar();
                }
            });
        });
    }
    
    // ensure no body overflow left after orientation change
    window.addEventListener('orientationchange', function() {
        if (window.innerWidth > 768) {
            document.body.style.overflow = '';
        }
    });
    
    // small adjustment for desktop close button
    const desktopCloseBtn = document.querySelector('.d-none.d-md-block');
    if (desktopCloseBtn) {
        desktopCloseBtn.addEventListener('click', (e) => {
            if (window.innerWidth > 768) {
                // collapse / expand desktop sidebar text visibility
                toggleSidebar();
            }
        });
    }
    
    //  any dynamic content need to refresh (just to be safe)
    console.log("Responsive dashboard ready — sidebar and table fully responsive");
</script>
<!-- Additional custom scripts from original project (optional but kept for compatibility) -->
<script src="./js/sidebars.js"></script>
<script src="./js/main.js"></script>
</body>
</html>
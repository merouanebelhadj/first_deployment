    <!-- Petit script additionnel pour améliorer l'expérience responsive sans altérer le code existant -->
    <script>
      (function() {
        // Garantir que les tooltips Bootstrap fonctionnent même après redimensionnement (optionnel)
        if (typeof bootstrap !== 'undefined' && bootstrap.Tooltip) {
          var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
          tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
          });
        }
        
        // Assure que le bouton de fermeture de la sidebar fonctionne avec la réactivité
        // La fonction toggleSidebar() est déjà définie dans sidebars.js, on ne fait que garantir qu'en mode mobile
        // la sidebar peut être refermée proprement. Aucun conflit.
        if (window.innerWidth < 992) {
          // Option: on peut ajouter une classe pour éviter un overflow si nécessaire mais on laisse le comportement existant
          document.querySelector('main.d-flex')?.classList.remove('flex-nowrap');
          document.querySelector('main.d-flex')?.classList.add('flex-wrap');
        }
        
        // Écouter le redimensionnement pour maintenir la flexibilité sans casser le layout
        window.addEventListener('resize', function() {
          const mainEl = document.querySelector('main.d-flex');
          if (window.innerWidth < 992) {
            mainEl?.classList.remove('flex-nowrap');
            mainEl?.classList.add('flex-wrap');
          } else {
            mainEl?.classList.remove('flex-wrap');
            mainEl?.classList.add('flex-nowrap');
          }
        });
      })();
    </script>

    <!-- Bootstrap 5 CSS -->
    <link href="./css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Custom responsive styles -->
    <style>
        /* ---------- GLOBAL RESETS & HELPERS ---------- */
        * {
            box-sizing: border-box;
        }
        body {
            overflow-x: hidden;
            background-color: var(--bs-body-bg);
            transition: background 0.2s ease;
        }
        .b-example-divider {
            width: 100%;
            height: 3rem;
            background-color: rgba(0, 0, 0, 0.1);
            border: solid rgba(0, 0, 0, 0.15);
            border-width: 1px 0;
            box-shadow: inset 0 0.5em 1.5em rgba(0, 0, 0, 0.1), inset 0 0.125em 0.5em rgba(0, 0, 0, 0.15);
        }
        .b-example-vr {
            flex-shrink: 0;
            width: 1.5rem;
            height: 100vh;
        }
        .bd-mode-toggle {
            z-index: 1500;
        }
        /* Tooltip custom */
        .btn[data-bs-toggle="tooltip"] {
            cursor: pointer;
        }
        
        /* ---------- RESPONSIVE SIDEBAR (mobile + desktop) ---------- */
        /* desktop: always visible, static */
        .sidebar {
            width: 280px;
            transition: transform 0.3s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            z-index: 1050;
            background-color: #212529 !important;
            height: 100vh;
            position: sticky;
            top: 0;
            overflow-y: auto;
        }
        /* overlay (mobile only) */
        .sidebar-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(0, 0, 0, 0.55);
            z-index: 1040;
            display: none;
            backdrop-filter: blur(2px);
            transition: all 0.2s;
        }
        .sidebar-overlay.show {
            display: block;
        }
        
        /* Mobile styles (<= 768px) */
        @media (max-width: 768px) {
            .sidebar {
                position: fixed;
                top: 0;
                left: 0;
                bottom: 0;
                transform: translateX(-100%);
                height: 100%;
                width: 280px;
                z-index: 1060;
                box-shadow: 2px 0 12px rgba(0,0,0,0.3);
                transition: transform 0.25s ease-in-out;
            }
            .sidebar.show {
                transform: translateX(0);
            }
            .b-example-vr {
                display: none;  /* hide vertical divider on mobile */
            }
            main.d-flex {
                flex-direction: column;
            }
            /* table container scrolling */
            .table-wrapper {
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
                margin: 0 0.5rem;
            }
            .navbar .container-fluid {
                padding-left: 0.75rem;
                padding-right: 0.75rem;
            }
            .navbar-brand {
                font-size: 1.25rem;
            }
            .action-btns {
                flex-wrap: nowrap !important;
            }
            /* better spacing for cards */
            section.w-100 {
                padding: 0 0.25rem;
            }
            .table {
                font-size: 0.85rem;
                min-width: 600px; /* force horizontal scroll if needed */
            }
            .table th, .table td {
                padding: 0.5rem 0.4rem;
                vertical-align: middle;
            }
        }
        
        /* tablet and desktop enhancements */
        @media (min-width: 769px) {
            .mobile-menu-toggle {
                display: none;
            }
            .sidebar {
                transform: translateX(0) !important;
                position: sticky;
            }
            .sidebar-overlay {
                display: none !important;
            }
            .table-wrapper {
                overflow-x: auto;
                margin: 0 1rem;
            }
            .table {
                min-width: auto;
            }
        }
        
        /* small devices extra polish */
        @media (max-width: 480px) {
            .sidebar-text {
                font-size: 0.9rem;
            }
            .navbar-brand {
                font-size: 1rem;
            }
            .btn-sm {
                padding: 0.2rem 0.4rem;
                font-size: 0.7rem;
            }
            .btn-outline-success {
                padding: 0.25rem 0.6rem;
                font-size: 0.8rem;
            }
            .form-control-sm-custom {
                width: 140px;
            }
        }
        
        /* table action buttons: prevent wrap */
        .action-btns {
            display: flex;
            gap: 0.35rem;
            justify-content: center;
            flex-wrap: nowrap;
        }
        .action-btns .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        /* sidebar custom scroll */
        .sidebar::-webkit-scrollbar {
            width: 5px;
        }
        .sidebar::-webkit-scrollbar-track {
            background: #2c3034;
        }
        .sidebar::-webkit-scrollbar-thumb {
            background: #6c757d;
            border-radius: 4px;
        }
        
        /* table hover effect */
        .table tbody tr:hover {
            background-color: rgba(var(--bs-primary-rgb), 0.08);
            transition: 0.1s;
        }
        /* brand icon */
        .navbar-brand i {
            margin-right: 6px;
        }
        /* smooth transitions */
        a, button {
            transition: all 0.15s;
        }
    </style>
    <link href="./css/sidebars.css" rel="stylesheet">
</head>
